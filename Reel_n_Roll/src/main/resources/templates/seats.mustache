<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Seats</title>
</head>
<body>
    <h1>All Seats</h1>

    <table border="1">
        <tr>
            <th>Seat Number</th>
            <th>Type</th>
            <th>Theatre ID</th>
        </tr>
        {{#seats}}
        <tr>
            <td>{{seatNumber}}</td>
            <td>{{seatType}}</td>
            {{#theatre}}
            <td>{{theatreId}}</td>
            {{/theatre}}
            {{^theatre}}
            <td>N/A</td>
            {{/theatre}}
        </tr>
        {{/seats}}
    </table>

    <br>
    <a href="/index.html">Back to Home</a>
    <a href="/seats/add">Add New Seat</a>
</body>
</html>